rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }
    
    function hasRole(role) {
      return isAuthenticated() && getUserData().role == role;
    }

    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin') ||
        request.auth.token.email == "jasimhussein8@gmail.com"
      );
    }

    // Users
    match /users/{uid} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && (request.auth.uid == uid || isAdmin());
      allow update: if isAuthenticated() && (request.auth.uid == uid || isAdmin()) && 
                    (request.resource.data.role == resource.data.role || resource.data.isProfileComplete == false || isAdmin());
      allow delete: if isAdmin();
    }

    // Materials
    match /materials/{id} {
      allow read: if isAuthenticated();
      allow create: if hasRole('teacher') || isAdmin();
      allow update: if (hasRole('teacher') && resource.data.teacherId == request.auth.uid) || isAdmin();
      allow delete: if (hasRole('teacher') && resource.data.teacherId == request.auth.uid) || isAdmin();
    }

    // Classes
    match /classes/{classId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    // Attendance
    match /attendance/{id} {
      allow read: if isAuthenticated();
      allow create: if hasRole('teacher') || isAdmin();
      allow update: if hasRole('teacher') || isAdmin();
      allow delete: if isAdmin();
    }

    // Grades
    match /grades/{id} {
      allow read: if isAuthenticated();
      allow create: if hasRole('teacher') || isAdmin();
      allow update: if hasRole('teacher') || isAdmin();
      allow delete: if isAdmin();
    }

    // Assignments
    match /assignments/{id} {
      allow read: if isAuthenticated();
      allow create: if hasRole('teacher') || isAdmin();
      allow update: if hasRole('teacher') || isAdmin();
      allow delete: if isAdmin();
    }

    // Submissions
    match /submissions/{id} {
      allow read: if isAuthenticated();
      allow create: if hasRole('student');
      allow update: if hasRole('student') || hasRole('teacher') || isAdmin();
    }

    // Notifications
    match /notifications/{id} {
      allow read: if isOwner(resource.data.recipientId);
      allow create: if isAuthenticated();
      allow update: if isOwner(resource.data.recipientId);
    }

    // Messages
    match /messages/{id} {
      allow read: if isOwner(resource.data.senderId) || isOwner(resource.data.receiverId);
      allow create: if isAuthenticated();
    }
  }
}
